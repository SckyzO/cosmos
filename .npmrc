# Force pnpm store outside the workspace bind-mount to avoid permission issues
# and to keep the workspace clean. Inside the cosmos-dev container, $HOME is
# /home/node, owned by the node user (UID = host UID via build args).
store-dir=${HOME}/.pnpm-store
# Auto-install peers (pnpm 10 default behavior, explicit for clarity)
auto-install-peers=true
# Strict peer deps OFF for now (Storybook 10 + Vite 7 still has noisy peers)
strict-peer-dependencies=false
