{
  "name": "cosmos",
  "version": "0.0.0",
  "private": true,
  "description": "Design system for sckyzo's projects (React 19 + Tailwind 4 + Storybook 10)",
  "license": "MIT",
  "author": "SckyzO",
  "homepage": "https://github.com/SckyzO/cosmos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SckyzO/cosmos.git"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter '@cosmos/e2e' test",
    "build": "pnpm -r build",
    "storybook": "pnpm --filter '@cosmos/storybook' dev",
    "storybook:build": "pnpm --filter '@cosmos/storybook' build",
    "ci": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
