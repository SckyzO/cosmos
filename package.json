{
  "name": "cosmos",
  "version": "0.0.0",
  "private": true,
  "description": "Design system for sckyzo's projects (React 19 + Tailwind 4 + Storybook 9)",
  "license": "MIT",
  "author": "SckyzO",
  "homepage": "https://github.com/SckyzO/cosmos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SckyzO/cosmos.git"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter '@cosmos/e2e' test",
    "build": "pnpm -r build",
    "storybook": "pnpm --filter '@cosmos/storybook' dev",
    "storybook:build": "pnpm --filter '@cosmos/storybook' build",
    "ci": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "typescript": "^5.9.0"
  }
}
