{
  "name": "@sckyzo/cosmos-charts",
  "version": "0.0.2",
  "description": "React chart components for the Cosmos design system — themeable ApexCharts 5 wrappers (bar, line, area, donut, radial gauges, sparkline, treemap, realtime) with light/dark support.",
  "license": "MIT",
  "author": "SckyzO",
  "homepage": "https://github.com/SckyzO/cosmos/tree/main/packages/charts",
  "bugs": "https://github.com/SckyzO/cosmos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SckyzO/cosmos.git",
    "directory": "packages/charts"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Stories tested via @cosmos/storybook addon-vitest (apps/storybook).'",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "apexcharts": "^5.16.0",
    "react-apexcharts": "^2.1.1"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-system",
    "react",
    "react-19",
    "charts",
    "apexcharts",
    "cosmos"
  ]
}
