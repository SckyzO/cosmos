{
  "name": "@sckyzo/cosmos-theme",
  "version": "0.0.1",
  "description": "Tailwind 4 theme and design tokens for the Cosmos design system — palette, typography, radii and light/dark CSS variables.",
  "license": "MIT",
  "author": "SckyzO",
  "homepage": "https://github.com/SckyzO/cosmos/tree/main/packages/theme",
  "bugs": "https://github.com/SckyzO/cosmos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SckyzO/cosmos.git",
    "directory": "packages/theme"
  },
  "type": "module",
  "main": "./css/tailwind-tokens.css",
  "exports": {
    ".": "./css/tailwind-tokens.css",
    "./tailwind": "./css/tailwind-tokens.css",
    "./vars": "./css/css-vars.css",
    "./fonts": "./css/fonts.css",
    "./package.json": "./package.json"
  },
  "files": [
