    "lint:fix": "echo 'CSS-only package, no JS lint needed'",
    "typecheck": "echo 'CSS-only package, no TS check needed'",
    "test": "echo 'CSS-only package, no tests yet'",
    "build": "echo 'CSS-only package, no build step needed'"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "tailwindcss",
    "tailwind-v4",
    "css-variables",
    "cosmos"
