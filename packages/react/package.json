{
  "name": "@sckyzo/cosmos-react",
  "version": "0.0.2",
  "description": "React 19 + Tailwind 4 UI component library — 135+ themeable, accessible components (forms, overlays, navigation, tables, data display) with built-in light/dark mode.",
  "license": "MIT",
  "author": "SckyzO",
  "homepage": "https://github.com/SckyzO/cosmos/tree/main/packages/react",
  "bugs": "https://github.com/SckyzO/cosmos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SckyzO/cosmos.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Stories tested via @cosmos/storybook addon-vitest (apps/storybook).'",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@sckyzo/cosmos-theme": "workspace:*",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.16.0",
    "react-day-picker": "^10.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "storybook": "^10.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "design-system",
    "react",
    "react-19",
    "tailwindcss",
    "tailwind-v4",
    "components",
    "cosmos"
  ]
}
