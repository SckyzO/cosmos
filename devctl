#!/usr/bin/env bash
# cosmos — devctl wrapper. All commands run inside cosmos-dev as non-root user
# matching the host UID/GID. The host needs only: docker, git, gh, bash.

set -euo pipefail

DEV_IMAGE="cosmos-dev:latest"
WORKSPACE="/workspace"
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"
DOCKER_RUN="docker run --rm -v $(pwd):${WORKSPACE} -w ${WORKSPACE} -u ${HOST_UID}:${HOST_GID} -e HOME=/home/node"
DOCKER_RUN_IT="docker run -it --rm -v $(pwd):${WORKSPACE} -w ${WORKSPACE} -u ${HOST_UID}:${HOST_GID} -e HOME=/home/node"
DOCKER_RUN_SB="docker run --rm -v $(pwd):${WORKSPACE} -w ${WORKSPACE} -u ${HOST_UID}:${HOST_GID} -e HOME=/home/node -p 6006:6006"

ensure_image() {
    if ! docker image inspect "$DEV_IMAGE" >/dev/null 2>&1; then
        echo "→ Building cosmos-dev image (first run)..."
        docker build \
            --build-arg "USER_UID=${HOST_UID}" \
            --build-arg "USER_GID=${HOST_GID}" \
            -t "$DEV_IMAGE" -f config/docker/Dockerfile.dev .
    fi
}

case "${1:-help}" in
    build)
        docker build \
            --build-arg "USER_UID=${HOST_UID}" \
            --build-arg "USER_GID=${HOST_GID}" \
            -t "$DEV_IMAGE" -f config/docker/Dockerfile.dev .
        ;;
    rebuild)
        docker build --no-cache \
            --build-arg "USER_UID=${HOST_UID}" \
            --build-arg "USER_GID=${HOST_GID}" \
            -t "$DEV_IMAGE" -f config/docker/Dockerfile.dev .
        ;;
    shell)
        ensure_image
        $DOCKER_RUN_IT "$DEV_IMAGE" bash
        ;;
    storybook)
        ensure_image
        $DOCKER_RUN_SB "$DEV_IMAGE" pnpm storybook
        ;;
    e2e)
        ensure_image
        $DOCKER_RUN "$DEV_IMAGE" pnpm test:e2e
        ;;
    run)
        ensure_image
        shift
        $DOCKER_RUN "$DEV_IMAGE" "$@"
        ;;
    help|--help|-h)
        cat <<USAGE
cosmos devctl — docker-driven dev wrapper

USAGE:
    ./devctl <command> [args...]

COMMANDS:
    build         Build the cosmos-dev image (UID/GID matched to host)
    rebuild       Rebuild without cache
    shell         Interactive shell as host user
    storybook     Storybook dev server (http://localhost:6006, no auto-open)
    e2e           Playwright e2e tests (screenshots in screenshots/)
    run <cmd>     Run an arbitrary command in container (as host user)
                  e.g.: ./devctl run pnpm install
                        ./devctl run pnpm --filter @sckyzo/cosmos-react test
    help          Show this help

Prefer make targets when available — see ./Makefile.
USAGE
        ;;
    *)
        echo "Unknown command: $1" >&2
        exit 1
        ;;
esac
