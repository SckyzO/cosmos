# cosmos-dev image
# Node 22 LTS Debian (Playwright needs system libs Alpine doesn't bundle).
# Embeds: pnpm 10, Playwright browsers, Storybook deps, system tools for linters.
#
# Build:  docker build -t cosmos-dev:latest -f config/docker/Dockerfile.dev .
# Usage:  driven by ./devctl and Makefile targets.

FROM node:22-bookworm-slim

# --- System packages (Playwright + linters) ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl wget git make \
    # Playwright Chromium / Firefox runtime libs
    libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxkbcommon0 libatspi2.0-0 libxcomposite1 \
    libxdamage1 libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 \
    libcairo2 libasound2 \
    # Useful CLI utilities
    jq vim less procps \
 && rm -rf /var/lib/apt/lists/*

# --- pnpm via corepack (official, version pinned in repo via package.json packageManager field) ---
RUN corepack enable

WORKDIR /workspace

# Pre-install Playwright browsers in a cached layer (long step, rarely changes).
# Browser binaries land in /ms-playwright (default).
RUN npx -y playwright@latest install --with-deps chromium firefox

# Default to interactive shell.
CMD ["bash"]
