# cosmos-dev image
# Node 26 Debian (Playwright needs system libs Alpine doesn't bundle).
# Node 26 is the Current line and enters LTS on 2026-10-28.
# Embeds: pnpm 10, Playwright browsers (Chromium + Firefox), Storybook deps.
# Runs as non-root 'node' user, with UID/GID matching the host (build args).
#
# Build (preferred, via Makefile):
#   make build-image
#
# Manual:
#   docker build \
#     --build-arg USER_UID=$(id -u) \
#     --build-arg USER_GID=$(id -g) \
#     -t cosmos-dev:latest -f config/docker/Dockerfile.dev .

FROM node:26-bookworm-slim

# --- Root: minimal utilities + corepack -------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl wget git make jq vim less procps \
 && rm -rf /var/lib/apt/lists/*

# Enable pnpm via corepack (version pinned in repo via package.json packageManager field).
# Node 25+ no longer bundles corepack, so install it from npm rather than pinning pnpm
# here — that keeps `packageManager` in package.json the single source of truth.
RUN npm install -g corepack@latest \
 && corepack enable

# --- Root: install Playwright system deps (most accurate list comes from playwright itself)
RUN npx -y playwright@latest install-deps chromium firefox \
 && rm -rf /var/lib/apt/lists/*

# --- UID/GID matching host (default 1000:1000 if not passed) ----------------
ARG USER_UID=1000
ARG USER_GID=1000

# Adjust 'node' user (already exists in the node image with UID 1000) to match host.
RUN if [ "$USER_UID" != "1000" ] || [ "$USER_GID" != "1000" ]; then \
        groupmod -g "$USER_GID" node && usermod -u "$USER_UID" -g "$USER_GID" node; \
    fi

# --- Switch to non-root user ------------------------------------------------
USER node
WORKDIR /workspace

# --- User: install Playwright browsers (cached in /home/node/.cache/ms-playwright)
RUN npx -y playwright@latest install chromium firefox

# Tell pnpm to use a project-local store so it survives bind mounts.
ENV PNPM_HOME=/home/node/.pnpm-store
ENV PATH=$PNPM_HOME:$PATH

CMD ["bash"]
